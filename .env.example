# ─────────────────────────────────────────────────
# Stock4N — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# Timezone
TZ=Asia/Ho_Chi_Minh

# ═══════════════════════════════════════════════════
# Vnstock API Key (vnstock 3.4.0+)
# ═══════════════════════════════════════════════════
# Register FREE at: https://vnstocks.com/login
# Benefits:
#   - 60 requests/minute (vs 20 guest mode)
#   - 8 quarters financial data (vs 4 guest)
#   - Priority support for KBS data source
# VNSTOCK_API_KEY=vnstock_YOUR_KEY_HERE

# ═══════════════════════════════════════════════════
# Google Gemini API Key (for AI stock analysis)
# ═══════════════════════════════════════════════════
# Get your key at: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your_google_api_key_here

# Optional: Override AI model (default: gemini-2.0-flash)
# AI_MODEL=gemini-2.0-flash
